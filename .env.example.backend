# Backend Environment Variables
# Copy this to Railway project settings → Environment Variables

# Database Connection
# MySQL Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/friend_tracker

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# JWT Secret Key (use a strong random string)
SECRET_KEY=your_secret_key_here_change_in_production

# Environment
ENVIRONMENT=production

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app

# Optional: Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
